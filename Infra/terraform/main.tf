terraform {
  required_version = ">= 1.5.0"

  backend "s3" {}

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = "us-east-1"
}

variable "public_key" {
  description = "SSH public key generated by the workflow"
  type        = string
}

# Find a recent Amazon Linux 2 AMI
data "aws_ami" "amazon_linux" {
  most_recent = true
  owners      = ["amazon"]

  filter {
    name   = "name"
    values = ["amzn2-ami-hvm-*-x86_64-gp2"]
  }
}

# Default VPC
data "aws_vpc" "default" {
  default = true
}

# Default subnet
data "aws_subnets" "default" {
  filter {
    name   = "vpc-id"
    values = [data.aws_vpc.default.id]
  }

  filter {
    name   = "default-for-az"
    values = ["true"]
  }
}

# Key pair created in AWS from the public key generated by the workflow
resource "aws_key_pair" "eventhub_key" {
  key_name   = "eventhub-deploy-key"
  public_key = var.public_key
}

# Security Group for EventHub
resource "aws_security_group" "eventhub_sg" {
  name        = "eventhub-sg"
  description = "Allow SSH, HTTP and Flask access to EventHub"
  vpc_id      = data.aws_vpc.default.id

  ingress {
    description = "SSH"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"] # lab use only
  }

  ingress {
    description = "HTTP"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    description = "Flask app"
    from_port   = 5000
    to_port     = 5000
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    description = "Allow all outbound traffic"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name        = "eventhub-sg"
    Environment = "Lab"
    Managed_By  = "Terraform"
  }
}

# EC2 instance
resource "aws_instance" "main" {
  ami                         = data.aws_ami.amazon_linux.id
  instance_type               = "t3.micro"
  subnet_id                   = data.aws_subnets.default.ids[0]
  vpc_security_group_ids      = [aws_security_group.eventhub_sg.id]
  key_name                    = aws_key_pair.eventhub_key.key_name
  associate_public_ip_address = true

  user_data = <<-EOF
            #!/bin/bash
            yum update -y
            yum install -y git python3 python3-pip

            mkdir -p /opt/eventhub
            chown -R ec2-user:ec2-user /opt/eventhub
            EOF

  tags = {
    Name        = "eventhub"
    Environment = "Lab"
    Managed_By  = "Terraform"
  }
}

output "instance_id" {
  value = aws_instance.main.id
}

output "public_ip" {
  value = aws_instance.main.public_ip
}

output "ssh_user" {
  value = "ec2-user"
}

output "application_url" {
  value = "http://${aws_instance.main.public_ip}:5000"
}